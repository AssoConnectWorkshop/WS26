# Supabase (create a dedicated project for call-tracker — do not reuse the WS26 one)
# Server-only: every read/write goes through the service-role client, there is
# no browser Supabase client, so neither var needs a NEXT_PUBLIC_ prefix.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Used only by scripts/migrate.mjs to run SQL migrations against Supabase
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Google Cloud OAuth client (Calendar API, "Web application" type)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match a redirect URI configured on the OAuth client, e.g.
# http://localhost:3000/api/auth/google/callback in dev, or
# https://<your-vercel-domain>/api/auth/google/callback in production
GOOGLE_REDIRECT_URI=

# Shared passcode gating access to the dashboard (single-user tool, no full auth system)
APP_PASSWORD=
